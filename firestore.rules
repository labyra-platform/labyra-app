rules_version = '2';

// =============================================================
// Labyra Platform — Firestore Security Rules
// =============================================================
// Multi-tenant model: all data lives under /tenants/{tenantId}/...
// Firebase Auth custom claims drive access:
//   - tenantId: string (required for any tenant-scoped access)
//   - role: 'admin' | 'superadmin' | 'member' | 'viewer'
//
// Super-admin = platform operator, can read across tenants.
// Otherwise, users only access their own tenant's subtree.
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function userTenantId() {
      return request.auth.token.tenantId;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && userRole() == 'superadmin';
    }

    function belongsToTenant(tenantId) {
      return isSignedIn() && userTenantId() == tenantId;
    }

    function isAdmin(tenantId) {
      return belongsToTenant(tenantId) && userRole() in ['admin', 'superadmin'];
    }

    function isWriter(tenantId) {
      return belongsToTenant(tenantId) && userRole() in ['admin', 'superadmin', 'member'];
    }

    // ---------- Tenant document ----------
    // /tenants/{tenantId} — metadata (name, plan, createdAt, etc.)
    match /tenants/{tenantId} {
      allow read: if belongsToTenant(tenantId) || isSuperAdmin();
      allow write: if isAdmin(tenantId) || isSuperAdmin();

      // ---------- All tenant data ----------
      // Catch-all for any sub-collection under a tenant.
      // Specific sub-collections may override below for tighter rules.
      match /{document=**} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isWriter(tenantId) || isSuperAdmin();
      }

      // ---------- Audit logs (write-only for non-admin) ----------
      // Members may append, only admins read.
      match /auditLogs/{logId} {
        allow create: if isWriter(tenantId);
        allow read: if isAdmin(tenantId) || isSuperAdmin();
        allow update, delete: if false;  // immutable
      }

      // ---------- Members sub-collection (admin-managed) ----------
      match /members/{memberId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isAdmin(tenantId) || isSuperAdmin();
      }
    }

    // ---------- Platform-level collections (super-admin only) ----------
    // Cross-tenant analytics, billing, etc.
    match /platform/{document=**} {
      allow read, write: if isSuperAdmin();
    }


    // ── Material Profiles (R183-2) ─────────────────────────────────────────
    // Global scientific reference data (crystal structure, bandgap, spectral
    // signatures, citations). Public read — anyone signed in can read.
    // Write restricted to superadmin (platform operator seeds via Admin SDK).
    match /materialProfiles/{formula} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();

      match /verifiedCitations/{citationId} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin();
      }

      match /recentFindings/{findingId} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin();
      }
    }

    // ---------- Default deny ----------
    // Anything not explicitly matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
    // AI conversations and messages (R160-ai-2a)
    match /tenants/{tenantId}/aiConversations/{conversationId} {
      allow read, write: if isWriter(tenantId);
      allow read, write: if isSuperAdmin();

      match /messages/{messageId} {
        allow read, write: if isWriter(tenantId);
        allow read, write: if isSuperAdmin();
      }
    }

    // AI provenance (audit trail — immutable from client)
    match /tenants/{tenantId}/aiProvenance/{messageId} {
      allow read: if isWriter(tenantId) || isSuperAdmin();
      allow write: if false; // server only via Admin SDK
    }


    // ── Papers (R160-ai-5b-1, R168-3.12: isAuthenticated → isSignedIn) ──
    match /tenants/{tenantId}/papers/{paperId} {
      allow read: if isSignedIn() && belongsToTenant(tenantId);
      // Writes through API + Admin SDK only
      allow create, update, delete: if false;

      match /chunks/{chunkId} {
        allow read: if isSignedIn() && belongsToTenant(tenantId);
        allow create, update, delete: if false;
      }

      // Citations stats subcollection (R166-6b)
      match /_stats/{statsId} {
        allow read: if isSignedIn() && belongsToTenant(tenantId);
        allow create, update, delete: if false;
      }
    }

    // ── Citations (R166-6a, explicit R168-3.12) ───────────────────
    // Tenant-isolated citation graph. Read-only from client; writes via
    // Admin SDK in paper-processing pipeline.
    match /tenants/{tenantId}/citations/{citationId} {
      allow read: if isSignedIn() && belongsToTenant(tenantId);
      allow create, update, delete: if false;
    }

    // ── Monthly usage (R160-ai-5b-1) ──────────────────────────────
    match /tenants/{tenantId}/usage/{yearMonth} {
      allow read: if isSignedIn() && belongsToTenant(tenantId);
      allow create, update, delete: if false;
    }
  }
}
