rules_version = '2';

// =============================================================
// Labyra Platform — Firestore Security Rules
// =============================================================
// Multi-tenant model: all data lives under /tenants/{tenantId}/...
// Firebase Auth custom claims drive access:
//   - tenantId: string (required for any tenant-scoped access)
//   - role: 'admin' | 'superadmin' | 'member' | 'viewer'
//
// Super-admin = platform operator, can read across tenants.
// Otherwise, users only access their own tenant's subtree.
//
// IMPORTANT — Firestore rules are ADDITIVE (OR-logic). If any match
// grants access, access is granted. There is therefore NO catch-all
// `match /{document=**}` inside `/tenants/{tenantId}` — every
// subcollection is listed explicitly so that admin-SDK-only or
// server-only collections cannot be reached via a broad allow.
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function userTenantId() {
      return request.auth.token.tenantId;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && userRole() == 'superadmin';
    }

    function belongsToTenant(tenantId) {
      return isSignedIn() && userTenantId() == tenantId;
    }

    function isAdmin(tenantId) {
      return belongsToTenant(tenantId) && userRole() in ['admin', 'superadmin'];
    }

    function isWriter(tenantId) {
      return belongsToTenant(tenantId) && userRole() in ['admin', 'superadmin', 'member'];
    }

    // =====================================================
    // Tenant subtree — every subcollection listed explicitly
    // =====================================================
    match /tenants/{tenantId} {

      // Tenant root doc — metadata (name, plan, createdAt)
      allow read: if belongsToTenant(tenantId) || isSuperAdmin();
      allow write: if isAdmin(tenantId) || isSuperAdmin();

      // ---------- Writable from client (role member+) ----------
      match /materials/{materialId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isWriter(tenantId) || isSuperAdmin();
      }

      match /samples/{sampleId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isWriter(tenantId) || isSuperAdmin();
      }

      match /experiments/{experimentId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isWriter(tenantId) || isSuperAdmin();
      }

      // Spectra is the canonical name (worker is source of truth).
      // Not "measurements" — that name is wrong.
      match /spectra/{spectrumId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isWriter(tenantId) || isSuperAdmin();
      }

      match /equipment/{equipmentId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isWriter(tenantId) || isSuperAdmin();
      }
      // Chemicals — inventory. Writes go through API (Admin SDK) for
      // transaction integrity, but allow writer client writes too for parity
      // with other domains. Transactions sub-collection is append-only via API.
      match /chemicals/{chemicalId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isWriter(tenantId) || isSuperAdmin();
        match /transactions/{txId} {
          allow read: if belongsToTenant(tenantId) || isSuperAdmin();
          allow write: if false; // Admin SDK only — preserves audit integrity
        }
      }

      match /bookings/{bookingId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isWriter(tenantId) || isSuperAdmin();
      }

      match /aiConversations/{conversationId} {
        allow read, write: if isWriter(tenantId) || isSuperAdmin();

        match /messages/{messageId} {
          allow read, write: if isWriter(tenantId) || isSuperAdmin();
        }
      }

      // ---------- Client-readable, Admin-SDK-write-only ----------
      // Lifecycle managed by server pipelines (ingestion, analysis,
      // citation resolver, RAG processor). Any client write would
      // corrupt downstream state — denied.

      match /analyses/{analysisId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      match /citations/{citationId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      match /references/{referenceId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      match /papers/{paperId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if false;

        match /chunks/{chunkId} {
          allow read: if belongsToTenant(tenantId) || isSuperAdmin();
          allow write: if false;
        }

        match /_stats/{statsId} {
          allow read: if belongsToTenant(tenantId) || isSuperAdmin();
          allow write: if false;
        }
      }

      // AI provenance — audit trail of every model call. Read by
      // writers (so the UI can show citations + chain-of-tools), but
      // never client-writable. Admin SDK writes only.
      match /aiProvenance/{messageId} {
        allow read: if isWriter(tenantId) || isSuperAdmin();
        allow write: if false;
      }
      // Invites — onboarding ADR-031. Admin reads to manage in Members UI.
      // All writes via Admin SDK (create/revoke/accept routes). Client-deny.
      match /invites/{inviteId} {
        allow read: if isAdmin(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      // Monthly usage / quota counters. Client reads its own quota;
      // writes only via Admin SDK (cost-guard + telemetry). Allowing
      // client write here would be a free-AI bypass.
      match /usage/{yearMonth} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      // ---------- Admin-read, server-write-only ----------
      match /_costs/{costId} {
        allow read: if isAdmin(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      match /_evals/{evalId} {
        allow read: if isAdmin(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      // ---------- Server-only (no client access at all) ----------
      match /_rate_limits/{key} {
        allow read, write: if false;
      }

      match /_idempotency/{key} {
        allow read, write: if false;
      }

      // ---------- Audit logs (append-only by writer, immutable) ----------
      match /auditLogs/{logId} {
        allow create: if isWriter(tenantId);
        allow read: if isAdmin(tenantId) || isSuperAdmin();
        allow update, delete: if false;
      }

      // ---------- Members sub-collection (admin-managed) ----------
      match /members/{memberId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isAdmin(tenantId) || isSuperAdmin();
      }
    }

    // =====================================================
    // Material profiles — global, signed-in read
    // =====================================================
    // Scientific reference data (crystal structure, bandgap, spectral
    // signatures, citations). Public read for any signed-in user.
    // Writes restricted to superadmin (platform seeds via Admin SDK).
    match /materialProfiles/{formula} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();

      match /verifiedCitations/{citationId} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin();
      }

      match /recentFindings/{findingId} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin();
      }
    }

    // =====================================================
    // Platform-level collections (super-admin only)
    // Cross-tenant analytics, billing, etc.
    // =====================================================
    match /platform/{document=**} {
      allow read, write: if isSuperAdmin();
    }
    // PubChem lookup cache — server-side (Admin SDK) only. CHEM-2.
    match /_pubchem_cache/{cas} {
      allow read, write: if false;
    }

    // =====================================================
    // Default deny — MUST be last, at root scope. Anything not
    // explicitly matched above is denied.
    // =====================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
