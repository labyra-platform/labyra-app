rules_version = '2';

// =============================================================
// Labyra Platform — Firestore Security Rules
// =============================================================
// Multi-tenant model: all data lives under /tenants/{tenantId}/...
// Firebase Auth custom claims drive access:
//   - tenantId: string (required for any tenant-scoped access)
//   - role: 'admin' | 'superadmin' | 'member' | 'viewer'
//
// Super-admin = platform operator, can read across tenants.
// Otherwise, users only access their own tenant's subtree.
//
// IMPORTANT — Firestore rules are ADDITIVE (OR-logic). If any match
// grants access, access is granted. There is therefore NO catch-all
// `match /{document=**}` inside `/tenants/{tenantId}` — every
// subcollection is listed explicitly so that admin-SDK-only or
// server-only collections cannot be reached via a broad allow.
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function userTenantId() {
      return request.auth.token.tenantId;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && userRole() == 'superadmin';
    }

    function belongsToTenant(tenantId) {
      return isSignedIn() && userTenantId() == tenantId;
    }

    function isAdmin(tenantId) {
      return belongsToTenant(tenantId) && userRole() in ['admin', 'superadmin'];
    }

    function isWriter(tenantId) {
      return belongsToTenant(tenantId) && userRole() in ['admin', 'superadmin', 'member'];
    }

    // ── Feature access (R509) ────────────────────────────────────────
    // Ten collections are read straight from the client SDK via
    // useTenantCollection, so they never pass an API route and never saw the
    // R508 server checks. For those reads, THIS is the boundary.
    //
    // Costs one get() per query evaluation (not per document). That read is
    // the price of the gate being real; ADR-042 prices tiers by feature, so a
    // gate the client could skip was a billing bypass.
    function featureDisabledList(tenantId) {
      let path = /databases/$(database)/documents/tenants/$(tenantId)/featureAccess/main;
      let doc = exists(path) ? get(path).data : {};
      let groups = doc.get('groups', {});
      let gid = request.auth.token.get('groupId', '');
      // A group override REPLACES the tenant default (R491) — it is meant to
      // be read on its own, not as a diff against something else.
      return (gid != '' && groups.keys().hasAny([gid]))
        ? groups[gid]
        : doc.get('disabled', []);
    }

    function featureAllowed(tenantId, key) {
      // Admins set the gate; locking them out of it would be unrecoverable.
      return isAdmin(tenantId) || isSuperAdmin()
        || !featureDisabledList(tenantId).hasAny([key]);
    }

    function canRead(tenantId, feature) {
      return (belongsToTenant(tenantId) && featureAllowed(tenantId, feature)) || isSuperAdmin();
    }

    function canWrite(tenantId, feature) {
      return (isWriter(tenantId) && featureAllowed(tenantId, feature)) || isSuperAdmin();
    }

    // =====================================================
    // Tenant subtree — every subcollection listed explicitly
    // =====================================================
    match /tenants/{tenantId} {

      // Tenant root doc — metadata (name, plan, createdAt)
      allow read: if belongsToTenant(tenantId) || isSuperAdmin();
      allow write: if isAdmin(tenantId) || isSuperAdmin();

      // ---------- Writable from client (role member+) ----------
      match /materials/{materialId} {
        allow read: if canRead(tenantId, 'materials');
        allow write: if canWrite(tenantId, 'materials');
      }

      match /samples/{sampleId} {
        allow read: if canRead(tenantId, 'samples');
        allow write: if canWrite(tenantId, 'samples');
      }

      match /experiments/{experimentId} {
        allow read: if canRead(tenantId, 'experiments');
        allow write: if canWrite(tenantId, 'experiments');

        // Protocol instance (R271): an experiment's run, cloned from a template.
        // Firestore rules don't cascade to subcollections, so it needs its own
        // match. read = tenant member, write = writer (admin/member).
        match /protocol/{document=**} {
          allow read: if belongsToTenant(tenantId) || isSuperAdmin();
          allow write: if isWriter(tenantId) || isSuperAdmin();
        }
      }

      // Spectra is the canonical name (worker is source of truth).
      // Not "measurements" — that name is wrong.
      match /spectra/{spectrumId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isWriter(tenantId) || isSuperAdmin();
      }

      // DFT step presets (R280): a member's reusable parameter sets, read/written
      // from the client (compose node editor).
      match /dftStepPresets/{presetId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isWriter(tenantId) || isSuperAdmin();
      }

      // Per-user notifications (R290): only the owner reads/writes their own.
      // The worker (Admin SDK) bypasses rules to create job-done notifications.
      match /userNotifications/{uid}/items/{notifId} {
        allow read, write: if (belongsToTenant(tenantId) && request.auth.uid == uid)
          || isSuperAdmin();
      }

      match /equipment/{equipmentId} {
        allow read: if canRead(tenantId, 'equipment');
        allow write: if canWrite(tenantId, 'equipment');
      }
      // Chemicals — inventory. Writes go through API (Admin SDK) for
      // transaction integrity, but allow writer client writes too for parity
      // with other domains. Transactions sub-collection is append-only via API.
      match /chemicals/{chemicalId} {
        allow read: if canRead(tenantId, 'chemicals');
        allow write: if canWrite(tenantId, 'chemicals');
        match /transactions/{txId} {
          allow read: if belongsToTenant(tenantId) || isSuperAdmin();
          allow write: if false; // Admin SDK only — preserves audit integrity
        }
      }

      match /bookings/{bookingId} {
        allow read: if canRead(tenantId, 'bookings');
        allow write: if canWrite(tenantId, 'bookings');
      }

      // R498: DFT workflows/projects are read client-side (useTenantCollection
      // on the dashboard + computation workspace); without an explicit rule the
      // default-deny blocked them. Writes stay server-only (Admin SDK / worker).
      match /dftWorkflows/{workflowId} {
        allow read: if canRead(tenantId, 'computation');
        allow write: if false;
      }

      match /dftProjects/{projectId} {
        allow read: if canRead(tenantId, 'computation');
        allow write: if canWrite(tenantId, 'computation');

        match /{document=**} {
          allow read: if belongsToTenant(tenantId) || isSuperAdmin();
          allow write: if isWriter(tenantId) || isSuperAdmin();
        }
      }

      match /aiConversations/{conversationId} {
        allow read, write: if isWriter(tenantId) || isSuperAdmin();

        match /messages/{messageId} {
          allow read, write: if isWriter(tenantId) || isSuperAdmin();
        }
      }

      // Figure Studio per-user view configs (R5.4). Personal UI state, not
      // scientific data: a tenant member may read/write only their OWN configs
      // (doc.userId == auth.uid). Doc id is `${mid}__${figureKey}__${uid}`.
      match /figureConfigs/{configId} {
        allow read: if belongsToTenant(tenantId)
          && resource.data.userId == request.auth.uid;
        allow create, update: if belongsToTenant(tenantId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.tenantId == tenantId;
        allow delete: if belongsToTenant(tenantId)
          && resource.data.userId == request.auth.uid;
      }

      // Paper collections (Zotero-style, per-user). Distinct from groupId
      // (access scope): personal organization, readable/writable only by the
      // owner (doc.createdBy == auth.uid) within their tenant.
      match /collections/{collectionId} {
        allow read: if belongsToTenant(tenantId)
          && resource.data.createdBy == request.auth.uid;
        allow create: if belongsToTenant(tenantId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.tenantId == tenantId;
        allow update: if belongsToTenant(tenantId)
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == request.auth.uid;
        allow delete: if belongsToTenant(tenantId)
          && resource.data.createdBy == request.auth.uid;
      }

      // Favorite papers (per-user). A single doc per user (id == uid) holding a
      // paperIds array; readable/writable only by that user within their tenant.
      match /favorites/{userId} {
        allow read, write: if belongsToTenant(tenantId)
          && userId == request.auth.uid;
      }

      // Manuscripts (AI Science). Per-user, owner-only (createdBy == auth.uid)
      // within the tenant — same scope model as collections.
      match /manuscripts/{manuscriptId} {
        // R509: ownership is unchanged — the feature gate is ANDed on top, so
        // this can only restrict further, never widen.
        allow read: if belongsToTenant(tenantId)
          && featureAllowed(tenantId, 'manuscripts')
          && resource.data.createdBy == request.auth.uid;
        allow create: if belongsToTenant(tenantId)
          && featureAllowed(tenantId, 'manuscripts')
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.tenantId == tenantId;
        allow update: if belongsToTenant(tenantId)
          && featureAllowed(tenantId, 'manuscripts')
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == request.auth.uid;
        allow delete: if belongsToTenant(tenantId)
          && featureAllowed(tenantId, 'manuscripts')
          && resource.data.createdBy == request.auth.uid;
      }

      // Projects (Đề tài) — shared research-org entity (Benchling Studies).
      // Tenant members read; writers (member+) create/edit; admins delete.
      // Fine-grained project access (owner/members/advisor ∩ group RBAC) is v2.
      match /projects/{projectId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow create: if isWriter(tenantId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.tenantId == tenantId;
        allow update: if isWriter(tenantId) || isSuperAdmin();
        allow delete: if isAdmin(tenantId) || isSuperAdmin();
      }

      // Protocol templates (reusable node-graph procedures, R270) — same access
      // model as projects: tenant-readable, writer-writable, admin-deletable.
      match /protocolTemplates/{protocolTemplateId} {
        allow read: if canRead(tenantId, 'protocolTemplates');
        allow create: if isWriter(tenantId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.tenantId == tenantId;
        allow update: if isWriter(tenantId) || isSuperAdmin();
        allow delete: if isAdmin(tenantId) || isSuperAdmin();
      }

      // ---------- Client-readable, Admin-SDK-write-only ----------
      // Lifecycle managed by server pipelines (ingestion, analysis,
      // citation resolver, RAG processor). Any client write would
      // corrupt downstream state — denied.

      match /analyses/{analysisId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      match /citations/{citationId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      match /references/{referenceId} {
        allow read: if canRead(tenantId, 'references');
        allow write: if false;
      }

      match /papers/{paperId} {
        // ADR-034 TEAM-4a: group-scoped read. Same-tenant admins/superadmin see
        // all; members/leaders see only their group or lab-shared papers.
        allow read: if isSuperAdmin() ||
          (belongsToTenant(tenantId) && (
            isAdmin(tenantId) ||
            resource.data.get('groupId', 'lab-shared') == 'lab-shared' ||
            resource.data.get('groupId', 'lab-shared') == request.auth.token.groupId
          ));
        allow write: if false;

        // R495: chunk text IS paper content — inherit the parent's group guard
        // (one extra document read per rule evaluation; acceptable).
        match /chunks/{chunkId} {
          allow read: if isSuperAdmin() ||
            (belongsToTenant(tenantId) && (
              isAdmin(tenantId) ||
              get(/databases/$(database)/documents/tenants/$(tenantId)/papers/$(paperId))
                .data.get('groupId', 'lab-shared') == 'lab-shared' ||
              get(/databases/$(database)/documents/tenants/$(tenantId)/papers/$(paperId))
                .data.get('groupId', 'lab-shared') == request.auth.token.groupId
            ));
          allow write: if false;
        }

        match /_stats/{statsId} {
          allow read: if isSuperAdmin() ||
            (belongsToTenant(tenantId) && (
              isAdmin(tenantId) ||
              get(/databases/$(database)/documents/tenants/$(tenantId)/papers/$(paperId))
                .data.get('groupId', 'lab-shared') == 'lab-shared' ||
              get(/databases/$(database)/documents/tenants/$(tenantId)/papers/$(paperId))
                .data.get('groupId', 'lab-shared') == request.auth.token.groupId
            ));
          allow write: if false;
        }

        // C3a: PRIVATE per-user PDF annotations (highlights, drawings). Personal
        // reading marks, NOT shared scientific data — a tenant member reads and
        // writes ONLY their own (doc.userId == auth.uid). Coordinates are stored
        // normalized (0-1 per page) so they survive zoom/rotate/other devices.
        // Group-sharing is intentionally out of scope here (decided private).
        match /annotations/{annotationId} {
          allow read: if belongsToTenant(tenantId)
            && resource.data.userId == request.auth.uid;
          allow create: if belongsToTenant(tenantId)
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.tenantId == tenantId;
          allow update: if belongsToTenant(tenantId)
            && resource.data.userId == request.auth.uid
            && request.resource.data.userId == request.auth.uid;
          allow delete: if belongsToTenant(tenantId)
            && resource.data.userId == request.auth.uid;
        }

        // R237am: PRIVATE per-user Ask AI history — one Q&A thread per paper per
        // user. Read by the owner (so the chat re-opens with prior turns), but
        // ONLY the /api/papers/{id}/ask route writes (Admin SDK), to keep cost
        // accounting honest and stop a client forging assistant messages.
        match /qa/{messageId} {
          allow read: if belongsToTenant(tenantId)
            && resource.data.userId == request.auth.uid;
          allow write: if false;
        }

        // R223 pre-translate Lớp 1: worker-generated translated sections
        // (abstract/conclusion/headings). Read by any tenant member; the worker
        // (Admin SDK) is the only writer.
        match /pretranslations/{lang} {
          allow read: if belongsToTenant(tenantId) || isSuperAdmin();
          allow write: if false;
        }
      }

      // AI provenance — audit trail of every model call. Read by
      // writers (so the UI can show citations + chain-of-tools), but
      // never client-writable. Admin SDK writes only.
      match /aiProvenance/{messageId} {
        allow read: if isWriter(tenantId) || isSuperAdmin();
        allow write: if false;
      }
      // Invites — onboarding ADR-031. Admin reads to manage in Members UI.
      // All writes via Admin SDK (create/revoke/accept routes). Client-deny.
      match /invites/{inviteId} {
        allow read: if isAdmin(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      // Monthly usage / quota counters. Client reads its own quota;
      // writes only via Admin SDK (cost-guard + telemetry). Allowing
      // client write here would be a free-AI bypass.
      match /usage/{yearMonth} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      // ---------- Admin-read, server-write-only ----------
      match /_costs/{costId} {
        allow read: if isAdmin(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      match /_evals/{evalId} {
        allow read: if isAdmin(tenantId) || isSuperAdmin();
        allow write: if false;
      }

      // ---------- Server-only (no client access at all) ----------
      match /_rate_limits/{key} {
        allow read, write: if false;
      }

      match /_idempotency/{key} {
        allow read, write: if false;
      }

      // ---------- Audit logs (append-only by writer, immutable) ----------
      match /auditLogs/{logId} {
        allow create: if isWriter(tenantId);
        allow read: if isAdmin(tenantId) || isSuperAdmin();
        allow update, delete: if false;
      }

      // ---------- Members sub-collection (admin-managed) ----------
      match /members/{memberId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isAdmin(tenantId) || isSuperAdmin();
      }

      // ---------- Groups (research groups / teams) — ADR-034 TEAM-1 ----------
      // Owner (admin/superadmin) manages groups + appoints leaders. Any
      // tenant member may READ the group list (to see their group + leader).
      // Leadership claims are set server-side (Admin SDK), never client.
      // NOTE: per-group DATA isolation is TEAM-4 — not yet enforced here.
      match /groups/{groupId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isAdmin(tenantId) || isSuperAdmin();
      }
      // ---------- AI memory: tenant-shared context (ADR-035 L4) ----------
      // Lab house-style + glossary. Any tenant member may READ (injected into
      // their AI system prompt); only admins WRITE. Single doc per tenant in
      // practice, but rule is per-doc for forward-compat.
      match /aiContext/{contextId} {
        allow read: if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isAdmin(tenantId) || isSuperAdmin();
      }

      // ---------- AI memory: per-user episodic + semantic (ADR-035 L1/L2) ----------
      // Research knowledge is tenant-scoped AND user-private: only the owning
      // user, within their own tenant, may read/write. No cross-tenant
      // pollination; no cross-user reads (a tenant admin does NOT read another
      // member's private memories). Server (Admin SDK) bypasses these for
      // extraction writes.
      match /userMemories/{ownerUid}/{document=**} {
        allow read, write: if belongsToTenant(tenantId)
          && request.auth.uid == ownerUid;
      }
    }

    // =====================================================
    // Material profiles — global, signed-in read
    // =====================================================
    // Scientific reference data (crystal structure, bandgap, spectral
    // signatures, citations). Public read for any signed-in user.
    // Writes restricted to superadmin (platform seeds via Admin SDK).
    match /materialProfiles/{formula} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();

      match /verifiedCitations/{citationId} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin();
      }

      match /recentFindings/{findingId} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin();
      }
    }

    // =====================================================
    // Platform-level collections (super-admin only)
    // Cross-tenant analytics, billing, etc.
    // =====================================================
    match /platform/{document=**} {
      allow read, write: if isSuperAdmin();
    }
    // PubChem lookup cache — server-side (Admin SDK) only. CHEM-2.
    match /_pubchem_cache/{cas} {
      allow read, write: if false;
    }

    // =====================================================
    // AI preferences — TOP-LEVEL, per-user personal (ADR-035 L3)
    // =====================================================
    // Preferences belong to the human, not a tenant. A user in multiple
    // tenants keeps one set of preferences (language, verbosity, tone, ...).
    // This is the single intentional exception to the "everything under
    // tenants/{tid}" rule — and it holds personal settings, never scientific
    // data. Own-user only: nobody else (not even superadmin) reads another
    // user's preferences from the client.
    match /users/{uid}/aiPreferences/{settingsId} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // R523: display units. Same shape and same reason as aiPreferences — the
    // doc is the caller's own, so uid-match is the whole rule. Not feature
    // gated: choosing whether a band gap reads in eV or Ry is rendering, not
    // a billing boundary (ADR-042).
    match /users/{uid}/displayUnits/{settingsId} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // =====================================================
    // Default deny — MUST be last, at root scope. Anything not
    // explicitly matched above is denied.
    // =====================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
