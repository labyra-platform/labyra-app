rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Papers: tenant-scoped, nested under /tenants/ (R198 C2 — unified path format)
    // {path=**} covers {paperId}/v{N}.pdf and _uploads/{sessionId}.pdf
    match /tenants/{tenantId}/papers/{path=**} {
      allow read: if isAuthenticated() && isTenantMember(tenantId);
      // Writes only through API route (Admin SDK bypasses rules)
      allow write: if false;
    }

    // Spectra: tenant-scoped, raw is write-once via Admin SDK signed URL
    match /tenants/{tenantId}/spectra/{spectrumId}/{path=**} {
      allow read: if isAuthenticated() && isTenantMember(tenantId);
      // Writes only through API route signed URL (Admin SDK)
      allow write: if false;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isTenantMember(tenantId) {
      return request.auth.token.tenantId == tenantId;
    }
  }
}
